# Google Tag Manager — identifiant du conteneur web (format GTM-XXXXXXX)
# Laissez vide en développement si vous ne voulez pas charger GTM en local.
NEXT_PUBLIC_GTM_ID=

# URL du webhook qui reçoit les soumissions du formulaire de contact.
# Exemples : endpoint Make/Zapier/n8n, Slack incoming webhook, route interne.
# Si vide, les soumissions sont acceptées mais non transmises (mode dev).
CONTACT_WEBHOOK_URL=
